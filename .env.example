# PostgreSQL connection string (e.g. from Neon, Vercel Postgres, or any
# standard Postgres host). Must include ?sslmode=require for most hosted
# providers.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Secret used to sign session cookies (staff + participant login).
# Generate your own with: openssl rand -base64 32
SESSION_SECRET="change-me-to-a-long-random-string"
